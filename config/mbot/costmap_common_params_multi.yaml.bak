# my_smart_car/config/mbot/costmap_common_params_multi.yaml
# 多机器人版本的代价地图配置

# 机器人尺寸
robot_radius: 0.175
inflation_radius: 0.4  # 减小膨胀半径，避免机器人之间过度影响
cost_scaling_factor: 8.0

# 障碍物检测
obstacle_range: 2.5
raytrace_range: 3.0

# 代价地图类型
map_type: costmap
lethal_cost_threshold: 1

# 注意：scan话题名称将在launch文件中通过remap设置
observation_sources: scan
scan: {data_type: LaserScan, topic: scan, marking: true, clearing: true}
