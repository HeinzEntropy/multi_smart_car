<!-- multi_smart_car/launch/multi_robot_navigation.launch -->
<launch>
  <!-- 启动Gazebo仿真环境 -->
  <include file="$(find multi_smart_car)/launch/gazebo_multi_robot.launch"/>

  <!-- ========== 机器人1的导航系统 ========== -->
  <group ns="robot1">
    <!-- 包含参数化的AMCL启动文件 -->
    <include file="$(find multi_smart_car)/launch/amcl_multi.launch">
      <arg name="initial_pose_x" value="0.0"/>
      <arg name="initial_pose_y" value="0.0"/>
      <arg name="initial_pose_a" value="0.0"/>
      <arg name="odom_frame_id" value="robot1/odom"/>
      <arg name="base_frame_id" value="robot1_base_footprint"/>
    </include>

    <!-- Move Base导航 (保持原样，后续可同样模块化) -->
    <node pkg="move_base" type="move_base" name="move_base" output="screen" clear_params="true">
      <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/costmap_common_params.yaml" command="load" ns="global_costmap"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/costmap_common_params.yaml" command="load" ns="local_costmap"/>
      <rosparam file="$(find my_smart_car)/config/mbot/global_costmap_params.yaml" command="load"/>
      <rosparam file="$(find my_smart_car)/config/mbot/move_base_params.yaml" command="load"/>
      <rosparam file="$(find my_smart_car)/config/mbot/dwa_local_planner_params.yaml" command="load"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/local_costmap_params.yaml" command="load"/>
      <param name="global_costmap/global_frame" value="map"/>
      <param name="global_costmap/robot_base_frame" value="robot1_base_footprint"/>
      <param name="local_costmap/global_frame" value="robot1/odom"/>
      <param name="local_costmap/robot_base_frame" value="robot1_base_footprint"/>
      <remap from="cmd_vel" to="cmd_vel"/>
      <remap from="map" to="/map"/>
      <remap from="/people" to="/robot1/people"/>
    </node>
  </group>

  <!-- ========== 机器人2的导航系统 ========== -->
  <group ns="robot2">
    <!-- 包含参数化的AMCL启动文件 -->
    <include file="$(find multi_smart_car)/launch/amcl_multi.launch">
      <arg name="initial_pose_x" value="2.0"/>
      <arg name="initial_pose_y" value="0.0"/>
      <arg name="initial_pose_a" value="0.0"/>
      <arg name="odom_frame_id" value="robot2/odom"/>
      <arg name="base_frame_id" value="robot2_base_footprint"/>
    </include>

    <!-- Move Base导航 -->
    <node pkg="move_base" type="move_base" name="move_base" output="screen" clear_params="true">
      <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/costmap_common_params.yaml" command="load" ns="global_costmap"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/costmap_common_params.yaml" command="load" ns="local_costmap"/>
      <rosparam file="$(find my_smart_car)/config/mbot/global_costmap_params.yaml" command="load"/>
      <rosparam file="$(find my_smart_car)/config/mbot/move_base_params.yaml" command="load"/>
      <rosparam file="$(find my_smart_car)/config/mbot/dwa_local_planner_params.yaml" command="load"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/local_costmap_params.yaml" command="load"/>
      <param name="global_costmap/global_frame" value="map"/>
      <param name="global_costmap/robot_base_frame" value="robot2_base_footprint"/>
      <param name="local_costmap/global_frame" value="robot2/odom"/>
      <param name="local_costmap/robot_base_frame" value="robot2_base_footprint"/>
      <remap from="cmd_vel" to="cmd_vel"/>
      <remap from="map" to="/map"/>
      <remap from="/people" to="/robot2/people"/>
    </node>
  </group>

  <!-- ========== 机器人3的导航系统 ========== -->
  <group ns="robot3">
    <!-- 包含参数化的AMCL启动文件 -->
    <include file="$(find multi_smart_car)/launch/amcl_multi.launch">
      <arg name="initial_pose_x" value="4.0"/>
      <arg name="initial_pose_y" value="0.0"/>
      <arg name="initial_pose_a" value="0.0"/>
      <arg name="odom_frame_id" value="robot3/odom"/>
      <arg name="base_frame_id" value="robot3_base_footprint"/>
    </include>

    <!-- Move Base导航 -->
    <node pkg="move_base" type="move_base" name="move_base" output="screen" clear_params="true">
      <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/costmap_common_params.yaml" command="load" ns="global_costmap"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/costmap_common_params.yaml" command="load" ns="local_costmap"/>
      <rosparam file="$(find my_smart_car)/config/mbot/global_costmap_params.yaml" command="load"/>
      <rosparam file="$(find my_smart_car)/config/mbot/move_base_params.yaml" command="load"/>
      <rosparam file="$(find my_smart_car)/config/mbot/dwa_local_planner_params.yaml" command="load"/>
      <rosparam file="$(find multi_smart_car)/config/mbot/local_costmap_params.yaml" command="load"/>
      <param name="global_costmap/global_frame" value="map"/>
      <param name="global_costmap/robot_base_frame" value="robot3_base_footprint"/>
      <param name="local_costmap/global_frame" value="robot3/odom"/>
      <param name="local_costmap/robot_base_frame" value="robot3_base_footprint"/>
      <remap from="cmd_vel" to="cmd_vel"/>
      <remap from="map" to="/map"/>
      <remap from="/people" to="/robot3/people"/>
    </node>
  </group>

  <!-- ========== 编队控制器 ========== -->
  <node name="formation_controller" pkg="multi_smart_car"
        type="formation_controller.py" output="screen">
    <param name="formation_type" value="v_shape"/>
    <param name="formation_distance" value="1.5"/>
    <param name="num_robots" value="3"/>
  </node>

</launch>
