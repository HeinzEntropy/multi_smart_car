<!-- multi_smart_car/launch/multi_robot_formation.launch -->
<launch>
  <!-- 仿真模式参数 -->
  <arg name="use_gazebo" default="true"/>

  <!-- Gazebo仿真环境 -->
  <include if="$(arg use_gazebo)" file="$(find multi_smart_car)/launch/gazebo_world.launch">
    <arg name="world_file" value="$(find multi_smart_car)/world/obstacle.world"/>
  </include>

  <!-- ========== 主机器人（Robot 1） ========== -->
  <group ns="robot1">

    <!-- 加载机器人模型 -->
    <include file="$(find my_smart_car)/launch/load_robot.launch">
      <arg name="robot_namespace" value="robot1"/>
      <arg name="x" value="0.0"/>
      <arg name="y" value="0.0"/>
      <arg name="z" value="0.01"/>
      <arg name="yaw" value="0.0"/>
    </include>

    <!-- AMCL定位 -->
    <include file="$(find my_smart_car)/launch/amcl_multi.launch">
      <arg name="robot_namespace" value="robot1"/>
      <arg name="initial_pose_x" value="0.0"/>
      <arg name="initial_pose_y" value="0.0"/>
      <arg name="initial_pose_a" value="0.0"/>
    </include>

    <!-- Move Base导航 -->
    <include file="$(find my_smart_car)/launch/move_base_multi.launch">
      <arg name="robot_namespace" value="robot1"/>
    </include>

  </group>

  <!-- ========== 从机器人（Robot 2） ========== -->
  <group ns="robot2">

    <!-- 加载机器人模型 -->
    <include file="$(find my_smart_car)/launch/load_robot.launch">
      <arg name="robot_namespace" value="robot2"/>
      <arg name="x" value="2.0"/>
      <arg name="y" value="0.0"/>
      <arg name="z" value="0.01"/>
      <arg name="yaw" value="0.0"/>
    </include>

    <!-- AMCL定位 -->
    <include file="$(find my_smart_car)/launch/amcl_multi.launch">
      <arg name="robot_namespace" value="robot2"/>
      <arg name="initial_pose_x" value="2.0"/>
      <arg name="initial_pose_y" value="0.0"/>
      <arg name="initial_pose_a" value="0.0"/>
    </include>

    <!-- Move Base导航 -->
    <include file="$(find my_smart_car)/launch/move_base_multi.launch">
      <arg name="robot_namespace" value="robot2"/>
    </include>

  </group>

  <!-- ========== 从机器人（Robot 3） ========== -->
  <group ns="robot3">

    <!-- 加载机器人模型 -->
    <include file="$(find my_smart_car)/launch/load_robot.launch">
      <arg name="robot_namespace" value="robot3"/>
      <arg name="x" value="4.0"/>
      <arg name="y" value="0.0"/>
      <arg name="z" value="0.01"/>
      <arg name="yaw" value="0.0"/>
    </include>

    <!-- AMCL定位 -->
    <include file="$(find my_smart_car)/launch/amcl_multi.launch">
      <arg name="robot_namespace" value="robot3"/>
      <arg name="initial_pose_x" value="4.0"/>
      <arg name="initial_pose_y" value="0.0"/>
      <arg name="initial_pose_a" value="0.0"/>
    </include>

    <!-- Move Base导航 -->
    <include file="$(find my_smart_car)/launch/move_base_multi.launch">
      <arg name="robot_namespace" value="robot3"/>
    </include>

  </group>

  <!-- ========== 编队控制器 ========== -->
  <node name="formation_controller" pkg="multi_smart_car"
        type="formation_controller.py" output="screen">
    <param name="formation_type" value="v_shape"/>
    <param name="formation_distance" value="1.5"/>
    <param name="num_robots" value="3"/>
  </node>

  <!-- ========== RViz可视化 ========== -->
  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find multi_smart_car)/rviz/formation.rviz"/>

</launch>
